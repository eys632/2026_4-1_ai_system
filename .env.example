# Device: auto | cpu | cuda
JJ_RAG_DEVICE=auto

# Models
JJ_RAG_EMBED_MODEL=intfloat/multilingual-e5-small
JJ_RAG_ANSWER_MODEL=Qwen/Qwen2.5-1.5B-Instruct
JJ_RAG_CHUNK_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Retrieval
JJ_RAG_TOP_K=6

# Baseline chunking
JJ_RAG_BASE_CHUNK_CHARS=900
JJ_RAG_BASE_CHUNK_OVERLAP=150

# LLM chunking
JJ_RAG_LLM_CHUNK_MIN=450
JJ_RAG_LLM_CHUNK_MAX=1200

# Generation
JJ_RAG_MAX_NEW_TOKENS=512
